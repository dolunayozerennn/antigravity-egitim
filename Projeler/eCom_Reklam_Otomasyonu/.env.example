# eCom Reklam Otomasyonu — Gerekli Ortam Değişkenleri
# Gerçek değerler için: _knowledge/credentials/master.env

ENV=production

# Telegram
TELEGRAM_ECOM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# OpenAI (GPT-5 Mini)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-mini

# Perplexity (Marka Araştırması)
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# ImgBB (Görsel Hosting)
IMGBB_API_KEY=your_imgbb_key

# Kie AI (Seedance 2.0 + Nano Banana 2)
KIE_API_KEY=your_kie_key
KIE_BASE_URL=https://api.kie.ai/api/v1/

# ElevenLabs (Türkçe TTS)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_MODEL=eleven_multilingual_v2

# Replicate (Video + Ses Birleştirme)
REPLICATE_API_TOKEN=r8_...

# Notion (Üretim Logları)
NOTION_SOCIAL_TOKEN=ntn_...
NOTION_DB_ECOM_REKLAM=your_database_id
