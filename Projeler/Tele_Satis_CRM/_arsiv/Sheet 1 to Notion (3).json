    {
      "parameters": {
        "jsCode": "// === 7 GÜN KURALI İLE DUPLİKASYON DEĞERLENDİRME ===\n// Notion'dan dönen eşleşen kayıtları al\nconst searchResults = $input.all();\nconst originalData = $('Veri Temizleme').first().json;\n\n// 7 günlük pencere (milisaniye)\nconst SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000;\nconst now = new Date();\n\nlet isDuplicate = false;\nlet matchReason = '';\n\nfor (const result of searchResults) {\n  // Notion'dan dönen kaydın id'si yoksa (boş sonuç) atla\n  if (!result.json.id) continue;\n\n  // Kaydın oluşturulma tarihini al\n  const createdTime = new Date(result.json.createdTime || result.json.created_time || result.json.Eklendi || '');\n  const daysSinceCreated = (now - createdTime) / (1000 * 60 * 60 * 24);\n\n  // 7 gün içinde oluşturulmuşsa → duplike\n  if (daysSinceCreated <= 7) {\n    isDuplicate = true;\n\n    // Hangi alandan eşleştiğini bul\n    const matchedEmail = result.json.email && result.json.email.toLowerCase() === originalData.clean_email;\n    const matchedPhone = result.json.Phone && result.json.Phone.replace(/[\\s\\+\\-\\(\\)]/g, '') === originalData.clean_phone;\n\n    if (matchedEmail && matchedPhone) matchReason = 'Email + Telefon eşleşti';\n    else if (matchedEmail) matchReason = 'Email eşleşti';\n    else if (matchedPhone) matchReason = 'Telefon eşleşti';\n    else matchReason = 'Kayıt eşleşti';\n\n    matchReason += ` (${Math.round(daysSinceCreated)} gün önce kayıt var)`;\n    break;\n  }\n}\n\nreturn [{\n  json: {\n    ...originalData,\n    isDuplicate: isDuplicate,\n    matchReason: matchReason\n  }\n}];"
      },
