    {
      "parameters": {
        "jsCode": "// === VERİ TEMİZLEME ===\nconst item = $input.first().json;\n\n// Telefon: temizle ve formatla\nlet phone = String(item.phone_number || '');\nphone = phone.replace(/^p:\\+?/, '').replace(/[\\s\\+\\-\\(\\)]/g, '');\n\n// Türk numarası formatla: +90 5XX XXX XXXX\nif (phone.startsWith('90') && phone.length === 12) {\n  phone = '+' + phone.slice(0,2) + ' ' + phone.slice(2,5) + ' ' + phone.slice(5,8) + ' ' + phone.slice(8);\n} else {\n  phone = '+' + phone;\n}\n\n// İsim: baş harfleri büyük\nlet name = (item.full_name || '').trim();\nname = name.split(' ').map(w => {\n  if (!w) return '';\n  return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();\n}).join(' ');\n\n// Bütçe: alt çizgileri boşluğa çevir, sonra Notion opsiyonlarıyla eşleştir\nconst validBudgets = ['$0 - $20', '$20 - $50', '$50 - $150', '$150+'];\nlet budget = (item['100%_otomatik_youtube_kanalı_açmak_için_yatırım_bütçeniz_nedir?'] || '').replace(/_/g, ' ');\nif (!validBudgets.includes(budget)) budget = '';\n\n// Email: lowercase + trim\nlet email = (item.email || '').trim().toLowerCase();\n\nreturn [{\n  json: {\n    ...item,\n    clean_name: name,\n    clean_phone: phone,\n    clean_email: email,\n    clean_budget: budget\n  }\n}];"
      },
