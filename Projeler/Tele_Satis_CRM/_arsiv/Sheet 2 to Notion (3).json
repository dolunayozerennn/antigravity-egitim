    {
      "parameters": {
        "jsCode": "// === 7 GÜN KURALI İLE DUPLİKASYON DEĞERLENDİRME ===\nconst items = $('Veri Temizleme').all();\nconst searchResults = $input.all();\nconst now = new Date();\nconst results = [];\n\n// Her lead için ayrı ayrı kontrol et\nfor (const leadItem of items) {\n  const lead = leadItem.json;\n  let isDuplicate = false;\n  let matchReason = '';\n\n  for (const result of searchResults) {\n    const r = result.json;\n    if (!r.id) continue;\n\n    // simple: false format desteği\n    const resultEmail = (r.email || r.properties?.email?.email || '').toLowerCase();\n    const resultPhone = (r.Phone || r.properties?.Phone?.phone_number || '').replace(/[\\s\\+\\-\\(\\)p:]/g, '');\n    const cleanPhone = (lead.clean_phone || '').replace(/[\\s\\+\\-\\(\\)]/g, '');\n\n    const matchedEmail = resultEmail && resultEmail === lead.clean_email;\n    const matchedPhone = resultPhone && resultPhone === cleanPhone;\n\n    if (!matchedEmail && !matchedPhone) continue;\n\n    // Eşleşme var, 7 gün içinde mi?\n    const createdTime = new Date(r.createdTime || r.created_time || r.properties?.Eklendi?.created_time || '');\n    const daysSinceCreated = (now - createdTime) / (1000 * 60 * 60 * 24);\n\n    if (daysSinceCreated <= 7) {\n      isDuplicate = true;\n      if (matchedEmail && matchedPhone) matchReason = 'Email + Telefon eşleşti';\n      else if (matchedEmail) matchReason = 'Email eşleşti';\n      else matchReason = 'Telefon eşleşti';\n      matchReason += ` (${Math.round(daysSinceCreated)} gün önce kayıt var)`;\n      break;\n    }\n  }\n\n  results.push({\n    json: {\n      ...lead,\n      isDuplicate,\n      matchReason\n    }\n  });\n}\n\nreturn results;"
      },
