    {
      "parameters": {
        "jsCode": "// === VERİ TEMİZLEME ===\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const data = item.json;\n\n  // Telefon: temizle ve formatla\n  let phone = String(data.phone_number || '');\n  phone = phone.replace(/^p:\\+?/, '').replace(/[\\s\\+\\-\\(\\)]/g, '');\n\n  if (phone.startsWith('90') && phone.length === 12) {\n    phone = '+' + phone.slice(0,2) + ' ' + phone.slice(2,5) + ' ' + phone.slice(5,8) + ' ' + phone.slice(8);\n  } else {\n    phone = '+' + phone;\n  }\n\n  // İsim: baş harfleri büyük\n  let name = (data.full_name || '').trim();\n  name = name.split(' ').map(w => {\n    if (!w) return '';\n    return w.charAt(0).toUpperCase() + w.slice(1).toLowerCase();\n  }).join(' ');\n\n  // Bütçe\n  const validBudgets = ['$0 - $20', '$20 - $50', '$50 - $150', '$150+'];\n  let budget = (data['100%_otomatik_youtube_kanalı_açmak_için_yatırım_bütçeniz_nedir?'] || '').replace(/_/g, ' ');\n  if (!validBudgets.includes(budget)) budget = '';\n\n  // Email\n  let email = (data.email || '').trim().toLowerCase();\n\n  results.push({\n    json: {\n      ...data,\n      clean_name: name,\n      clean_phone: phone,\n      clean_email: email,\n      clean_budget: budget\n    }\n  });\n}\n\nreturn results;"
      },
