        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Sen bir içerik talebi sınıflandırma asistanısın. Müşterinin mesajını analiz et ve aşağıdaki kategorilerden birine ata.\\n\\nKategoriler:\\n- ecommerce_video: E-ticaret ürün tanıtım videosu, reklam filmi\\n- instagram_post: Tekli Instagram postu, poster, afiş, banner\\n- carousel: Kaydırmalı Instagram postu, çoklu slayt\\n- cinematic_video: Sinematik video, diyalog sahnesi, karşılıklı konuşma\\n- human_face_video: İnsan yüzü içeren video\\n- image_edit: Mevcut görseli düzenleme, revize\\n- needs_research: Önce marka/işletme araştırması gerekiyor\\n\\nYANIT FORMATI (sadece JSON):\\n{\\n  \\\"category\\\": \\\"kategori_adı\\\",\\n  \\\"confidence\\\": 0.0-1.0,\\n  \\\"reasoning\\\": \\\"Neden bu kategori\\\",\\n  \\\"suggested_prompt\\\": \\\"Üretim için önerilen İngilizce prompt\\\"\\n}\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.body.message }}\"\n    }\n  ],\n  \"temperature\": 0.2,\n  \"max_tokens\": 1000,\n  \"response_format\": { \"type\": \"json_object\" }\n}",
        "options": {}
      },
      "id": "groq-classify",
