    {
      "parameters": {
        "jsCode": "const groqResponse = $input.first().json;\nconst content = groqResponse.choices[0].message.content;\nconst parsed = JSON.parse(content);\n\nreturn [{\n  json: {\n    ...parsed,\n    originalMessage: $('Webhook Trigger').first().json.body.message,\n    imageUrl: $('Webhook Trigger').first().json.body.imageUrl || null,\n    websiteUrl: $('Webhook Trigger').first().json.body.websiteUrl || null\n  }\n}];"
      },
