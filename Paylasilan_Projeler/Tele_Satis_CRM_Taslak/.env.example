# Tele Satış CRM — Environment Variables

# Notion
NOTION_API_TOKEN=secret_BURAYA_KENDI_NOTION_API_TOKENINIZI_YAZIN
NOTION_DATABASE_ID=BURAYA_KENDI_NOTION_DATABASE_ID_NIZI_YAZIN

# Google Sheets
SPREADSHEET_ID=BURAYA_KENDI_SPREADSHEET_ID_NIZI_YAZIN
# Railway'de Service Account JSON'u tek satır olarak:
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Polling Aralığı (saniye)
POLL_INTERVAL_SECONDS=300

# Duplikasyon Penceresi (gün)
DEDUP_WINDOW_DAYS=7

# Hata Bildirimi (opsiyonel — tanımlı değilse sadece log'a yazar)
ERROR_NOTIFY_EMAIL=BURAYA_KENDI_EMAIL_ADRESINIZI_YAZIN
SMTP_USER=BURAYA_KENDI_GMAIL_ADRESINIZI_YAZIN
SMTP_APP_PASSWORD=BURAYA_GMAIL_APP_PASSWORD_YAZIN
