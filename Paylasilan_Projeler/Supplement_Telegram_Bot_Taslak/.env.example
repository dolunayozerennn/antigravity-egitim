# ══════════════════════════════════════════════════
# Supplement Buddy — Telegram Bot
# Ortam Değişkenleri (.env)
# ══════════════════════════════════════════════════
#
# Bu dosyayı .env olarak kopyala ve kendi değerlerini gir:
#   cp .env.example .env
#

# Telegram Bot Token (BotFather'dan al)
TELEGRAM_BOT_TOKEN=BURAYA_TELEGRAM_BOT_TOKEN_YAZIN

# Google Gemini API Key (https://aistudio.google.com)
GEMINI_API_KEY=BURAYA_GEMINI_API_KEY_YAZIN

# Gemini Model (varsayılan: gemini-2.5-flash)
# Alternatifler: gemini-2.0-flash, gemini-1.5-pro
GEMINI_MODEL=gemini-2.5-flash

# Notion Integration Token
# 1. https://www.notion.so/my-integrations adresinden integration oluştur
# 2. Token'ı buraya yapıştır
# 3. Database'e integration'ı bağla (Share > Invite)
NOTION_TOKEN=BURAYA_NOTION_INTEGRATION_TOKEN_YAZIN

# Notion Database ID
# Database URL'sindeki ID'yi al:
# https://www.notion.so/XXXXX?v=YYY → XXXXX kısmı database ID
NOTION_DB_ID=BURAYA_NOTION_DATABASE_ID_YAZIN

# Ortam (production / development)
# development modunda Notion'a yazma yapılmaz (dry-run)
ENV=production

# Telegram User ID kısıtlaması (opsiyonel)
# Virgülle ayrılmış Telegram user ID'leri
# Boş = herkes kullanabilir
ALLOWED_USER_IDS=
