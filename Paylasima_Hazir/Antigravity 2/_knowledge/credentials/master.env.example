# ==========================================================
# 🚀 ANTIGRAVITY 2 - MERKEZİ CREDENTIALS ŞABLONU
# ==========================================================
# Kullanım: Bu dosyanın adını 'master.env' olarak değiştirin
# ve X_BURAYAazan alanlara kendi tokenlarınızı yapıştırın.

# -----------------
# 1. AI SERVİSLERİ
# -----------------
OPENAI_API_KEY=sk-openai-anahtari-buraya
KIE_API_KEY=kie-ai-anahtari-buraya
GEMINI_API_KEY=gemini-anahtari-buraya

# -----------------
# 2. NOTION & DATABASE
# -----------------
NOTION_TOKEN=secret_notion-entegrasyon-anahtari
NOTION_DATABASE_ID=ana-veritabani-id-buraya
NOTION_REELS_DB_ID=reels-db-id-buraya
NOTION_YOUTUBE_DB_ID=youtube-db-id-buraya
NOTION_SOCIAL_TOKEN=secret_notion-sosyal-medya-token

# -----------------
# 3. YAZILIM / DEPLOY
# -----------------
RAILWAY_TOKEN=railway-token-buraya

# -----------------
# 4. BOT & LEAD (MÜŞTERİ) TOPLAMA
# -----------------
TELEGRAM_BOT_TOKEN=telegram-bot-token-buraya
TELEGRAM_ADMIN_CHAT_ID=telegram-chat-id-buraya
MAKE_WEBHOOK_URL=make-webhook-url-buraya
APIFY_API_KEY=apify-anahtari-buraya
HUNTER_API_KEY=hunter-io-anahtari-buraya
APOLLO_API_KEY=apollo-io-anahtari-buraya

# -----------------
# 5. GOOGLE WORKWORKSPACE
# -----------------
SPREADSHEET_ID=google-sheets-id-buraya
SOURCE_SPREADSHEET_ID=kaynak-google-sheets-id-buraya
